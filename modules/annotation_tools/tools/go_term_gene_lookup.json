{
  "id": "org.bioe234.function.annotation.go_term_gene_lookup.v1",
  "name": "GO Term Gene Lookup",
  "description": "Retrieve genes related to a GO term label, optionally filtered by organism.",
  "type": "function",
  "keywords": [
    "gene ontology",
    "GO",
    "genes",
    "annotation",
    "ontology",
    "organism"
  ],
  "date_created": null,
  "date_last_modified": null,
  "inputs": [
    {
      "name": "go_id",
      "type": "string",
      "description": "GO identifier, such as GO:0006979."
    },
    {
      "name": "go_label",
      "type": "string",
      "description": "GO term label, such as 'response to oxidative stress'."
    },
    {
      "name": "organism",
      "type": "string",
      "optional": true,
      "description": "Organism name, such as 'Saccharomyces cerevisiae'."
    },
    {
      "name": "max_genes",
      "type": "integer",
      "optional": true,
      "description": "Maximum number of genes to return. Default: 10."
    }
  ],
  "outputs": [
    {
      "type": "object",
      "description": "Structured gene lookup result."
    }
  ],
  "examples": [
