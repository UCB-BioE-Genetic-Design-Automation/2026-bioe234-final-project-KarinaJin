{
  "id": "org.bioe234.function.crispr.guide_designer.v1",
  "name": "CRISPR Guide Designer",
  "description": "Design a guide RNA for Cas9 or Cas12a by validating DNA, finding the PAM, extracting the protospacer, appending the scaffold, and converting DNA to RNA.",
  "type": "function",
  "keywords": [
    "CRISPR",
    "Cas9",
    "Cas12a",
    "gRNA",
    "crRNA",
    "PAM",
    "protospacer",
    "guide RNA"
  ],
  "date_created": null,
  "date_last_modified": null,
  "inputs": [
    {
      "name": "target",
      "type": "string",
      "description": "DNA target sequence to search."
    },
    {
      "name": "nuclease",
      "type": "string",
      "description": "CRISPR nuclease to use. Supported values: Cas9 or Cas12a."
    }
  ],
  "outputs": [
    {
      "type": "object",
      "description": "Dictionary containing nuclease, PAM index, PAM sequence, protospacer, guide DNA, and guide RNA."
    }
  ],
  "examples": [
